{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": ["config:recommended"],
	"prBodyTemplate": "{{{header}}}\n\n{{{table}}}\n\n{{{notes}}}\n\n{{{changelogs}}}\n\n{{controls}}",
	"rangeStrategy": "bump",
	"labels": ["Dependency Updates"],
	"reviewers": ["Kyvrixon"],
	"assignees": ["Kyvrixon"],
	"prFooter": "",
	"baseBranchPatterns": ["dev"],
	"dependencyDashboard": false,
	"packageRules": [
		{
			"matchUpdateTypes": [
				"major",
				"minor",
				"patch",
				"pin",
				"digest",
				"pinDigest",
				"bump",
				"replacement",
				"rollback"
			],
			"schedule": ["at any time"]
		}
	]
}
